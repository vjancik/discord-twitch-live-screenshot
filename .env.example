# Discord bot token (Bot -> Token in the Developer Portal).
DISCORD_TOKEN=

# Discord application (client) id, used to register the slash command.
DISCORD_APP_ID=

# Channel ID where auth-failure / recovery audit events are posted.
AUDIT_CHANNEL=

# Optional: register the slash command to a single guild for instant updates
# during development (global registration can take up to ~1h to propagate).
# DEV_GUILD_ID=

# Optional: pino log level (trace|debug|info|warn|error). Defaults to "info".
# LOG_LEVEL=info

# Optional: path to the ffmpeg binary. Defaults to "ffmpeg" (must be on PATH).
# FFMPEG_PATH=ffmpeg

# Optional: when true, suppress the native Twitch auto-embed (the useless
# profile-pic unfurl) on a user's message after the bot posts a screenshot for a
# channel it links to. Accepts true/false/1/0 (case-insensitive). Defaults to
# false. Requires the bot to have the "Manage Messages" permission in the channel.
# SUPPRESS_EMBEDS=false

# Optional: rate-limit windows in SECONDS (positive integers). Both default to 60
# (one per minute). Limiting is per-invocation, not per-screenshot: a message
# linking N channels is one user acquisition but N channel acquisitions.
#   RATE_LIMIT_PER_USER    — max one invocation per user (across all channels).
#   RATE_LIMIT_PER_CHANNEL — max one capture per Twitch-channel per Discord-channel.
# RATE_LIMIT_PER_USER=60
# RATE_LIMIT_PER_CHANNEL=60
